{
  "name": "@rosclaw/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "bash -lc 'shopt -s globstar nullglob; pnpm exec vitest run src/**/*.unit.test.ts'",
    "test:integration": "bash -lc 'shopt -s globstar nullglob; pnpm exec vitest run src/**/*.integration.test.ts'",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue-router": "^4.6.3",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6"
  }
}
