# URL of the rosbridge WebSocket server.
# Defaults to ws://<current host>:9090 when not set.
VITE_ROSBRIDGE_URL=ws://localhost:9090

# Optional RL WebSocket stream endpoint.
# Leave unset if RL streaming is not available in your local environment.
# VITE_RL_WS_URL=ws://localhost:8081

# Optional RL REST fallback endpoint.
# The UI will probe the base URL and a small set of snapshot-style suffixes.
# VITE_RL_REST_URL=http://localhost:8080
